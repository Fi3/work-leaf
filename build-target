#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
dist_dir="${WORK_LEAF_DIST_DIR:-$repo_root/dist}"
host_target="$(
  rustc -vV | awk -F': ' '/^host: / { print $2 }'
)"

if [[ -z "$host_target" ]]; then
  echo "could not determine Rust host target from rustc -vV" >&2
  exit 1
fi

target_list="${WORK_LEAF_BUILD_TARGETS:-$host_target}"

mkdir -p "$dist_dir"

for target in $target_list; do
  case "$target" in
    *-pc-windows-*)
      binary_name="work-leaf.exe"
      ;;
    *)
      binary_name="work-leaf"
      ;;
  esac

  echo "building work-leaf for $target"
  (cd "$repo_root" && cargo build --release --locked --bin work-leaf --target "$target")

  package_dir="$dist_dir/work-leaf-$target"
  rm -rf "$package_dir"
  mkdir -p "$package_dir"
  cp "$repo_root/target/$target/release/$binary_name" "$package_dir/$binary_name"

  case "$target" in
    *-pc-windows-*)
      if command -v zip >/dev/null 2>&1; then
        (cd "$dist_dir" && rm -f "work-leaf-$target.zip" && zip -qr "work-leaf-$target.zip" "work-leaf-$target")
      elif command -v powershell.exe >/dev/null 2>&1 || command -v powershell >/dev/null 2>&1; then
        powershell_bin="$(command -v powershell.exe || command -v powershell)"
        archive_path="$dist_dir/work-leaf-$target.zip"
        package_path="$package_dir"
        if command -v cygpath >/dev/null 2>&1; then
          archive_path="$(cygpath -w "$archive_path")"
          package_path="$(cygpath -w "$package_path")"
        fi
        "$powershell_bin" -NoProfile -Command "Compress-Archive -Path '$package_path' -DestinationPath '$archive_path' -Force"
      else
        echo "warning: zip or PowerShell not found; leaving unpacked package at $package_dir" >&2
      fi
      ;;
    *)
      (cd "$dist_dir" && rm -f "work-leaf-$target.tar.gz" && tar -czf "work-leaf-$target.tar.gz" "work-leaf-$target")
      ;;
  esac
done

cat <<EOF
Built Work Leaf packages in:
  $dist_dir

Each package contains the single work-leaf binary. Runtime machines need Codex
available on PATH; no Rust toolchain, Python SDK, or platform SDK is required.
Launch that binary with -d/--deamon to serve the HTTP API and web UI without
starting the CLI, or with -c/--cli <http-api-url> to attach the CLI to an
existing HTTP API.
EOF
