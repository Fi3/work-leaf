#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

bench_mode=0
remote_cli_mode=0
start_args=()
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --bench)
      bench_mode=1
      shift
      ;;
    -c|--cli)
      remote_cli_mode=1
      start_args+=("$1")
      if [[ "$#" -lt 2 ]]; then
        break
      fi
      start_args+=("$2")
      shift 2
      ;;
    *)
      start_args+=("$1")
      shift
      ;;
  esac
done

select_bench_bin_dir() {
  local results_dir="${WORK_LEAF_START_BENCH_RESULTS_DIR:-$repo_root/bench-results}"
  if [[ ! -d "$results_dir" ]]; then
    echo "no bench results directory found: $results_dir" >&2
    exit 1
  fi

  local artifact_dirs=()
  local orchestrator_bin="work-leaf-"
  orchestrator_bin+="orchestrator"
  while IFS= read -r artifact_dir; do
    if [[ -x "$artifact_dir/bin/work-leaf" && -x "$artifact_dir/bin/$orchestrator_bin" ]]; then
      artifact_dirs+=("$artifact_dir")
    fi
  done < <(
    find "$results_dir" -mindepth 1 -maxdepth 1 -type d -name '*-artifacts' -print | sort -r
  )

  if [[ "${#artifact_dirs[@]}" -eq 0 ]]; then
    echo "no bench artifacts with saved Work Leaf binaries found in $results_dir" >&2
    exit 1
  fi

  echo "Available benchs binaries:"
  local index=1
  local artifact_name
  local display_name
  for artifact_dir in "${artifact_dirs[@]}"; do
    artifact_name="$(basename "$artifact_dir")"
    display_name="${artifact_name%-artifacts}"
    printf '  %d) %s\n' "$index" "$display_name"
    index=$((index + 1))
  done

  local choice
  printf 'Choose a bench to run [1-%d]: ' "${#artifact_dirs[@]}"
  if ! read -r choice; then
    echo "no bench selection received" >&2
    exit 1
  fi
  if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#artifact_dirs[@]} )); then
    echo "invalid bench selection: $choice" >&2
    exit 1
  fi

  bin_dir="${artifact_dirs[$((choice - 1))]}/bin"
  echo "Running Work Leaf binaries from $bin_dir"
}

ensure_codex_sdk_python() {
  if [[ -n "${WORK_LEAF_CODEX_SDK_PYTHON:-}" ]]; then
    return
  fi

  local venv_dir="${WORK_LEAF_CODEX_SDK_VENV:-$repo_root/target/work-leaf-codex-sdk-venv}"
  local python="$venv_dir/bin/python"
  local source_python="${PYTHON:-python3}"

  if [[ ! -x "$python" ]]; then
    "$source_python" -m venv "$venv_dir"
  fi

  if ! "$python" - <<'PY' >/dev/null 2>&1; then
import openai_codex
PY
    "$python" -m pip install --upgrade openai-codex
  fi

  export WORK_LEAF_CODEX_SDK_PYTHON="$python"
}

if [[ "$bench_mode" == "1" ]]; then
  select_bench_bin_dir
elif [[ "${WORK_LEAF_START_SKIP_BUILD:-}" != "1" ]]; then
  (cd "$repo_root" && cargo build --release --bin work-leaf)
  bin_dir="${WORK_LEAF_START_BIN_DIR:-$repo_root/target/release}"
else
  bin_dir="${WORK_LEAF_START_BIN_DIR:-$repo_root/target/release}"
fi

cli_bin="$bin_dir/work-leaf"
if [[ "$remote_cli_mode" != "1" ]]; then
  ensure_codex_sdk_python
fi

set -- "${start_args[@]}"
exec "$cli_bin" "$@"
