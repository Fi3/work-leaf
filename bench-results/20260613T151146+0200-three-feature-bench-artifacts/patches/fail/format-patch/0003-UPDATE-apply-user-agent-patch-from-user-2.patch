+#[test]
+fn controller_routes_selected_agent_slash_commands_to_backend_command_path() {
+    let backend = FakeBackend::new(["launch reply"]);
+    let chat = CommandChat::new(PathBuf::from("/repo"), backend.clone());
+    let mut controller = WorkLeafController::new(chat);
+
+    let agent_id = controller.create_agent("inspect backend status").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+
+    controller.send_message(&agent_id, "/status").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+    controller
+        .send_message(&agent_id, "/fork feature-branch")
+        .unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+
+    let commands = backend.commands();
+    assert!(
+        commands
+            .iter()
+            .any(|(target, command)| target == &agent_id && command == "/status"),
+        "selected-agent /status must run through the backend command path"
+    );
+    assert!(
+        commands
+            .iter()
+            .any(|(target, command)| target == &agent_id && command == "/fork feature-branch"),
+        "selected-agent /fork must run through the backend command path"
+    );
+
+    let sends = backend.sends();
+    assert!(
+        !sends
+            .iter()
+            .any(|(_, prompt)| prompt == "/status" || prompt.starts_with("/fork")),
+        "slash commands must not reach the ordinary send/resume prompt path"
+    );
+
+    let snapshot = controller.snapshot();
+    let session = snapshot.session(&agent_id).expect("session exists");
+    assert!(session.lines.iter().any(|line| line == "user: /status"));
+    assert!(
+        session
+            .lines
+            .iter()
+            .any(|line| line == "backend command output: /status")
+    );
+    assert!(
+        session
+            .lines
+            .iter()
+            .any(|line| line == "backend command output: /fork feature-branch")
+    );
+}
+
