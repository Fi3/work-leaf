+    pub(crate) fn visual_toggle_kind(&mut self, kind: VisualKind) {
+        if let Some(visual) = self.visual.as_mut() {
+            if visual.kind == kind {
+                self.visual = None;
+            } else {
+                visual.kind = kind;
+            }
+        }
+    }
