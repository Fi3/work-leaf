+fn reading_order(a: CellPos, b: CellPos) -> (CellPos, CellPos) {
+    if (a.row, a.col) <= (b.row, b.col) {
+        (a, b)
+    } else {
+        (b, a)
+    }
+}
+
+fn charwise_columns(start: CellPos, end: CellPos, row: usize, len: usize) -> (usize, usize) {
+    let (lo, hi) = if start.row == end.row {
+        (start.col, end.col)
+    } else if row == start.row {
+        (start.col, len.saturating_sub(1))
+    } else if row == end.row {
+        (0, end.col)
+    } else {
+        (0, len.saturating_sub(1))
+    };
+    let hi = hi.min(len.saturating_sub(1));
+    let lo = lo.min(hi);
+    (lo, hi)
+}
+
+fn char_slice(line: &str, start: usize, end_inclusive: usize) -> String {
+    line.chars()
+        .skip(start)
+        .take(end_inclusive.saturating_sub(start) + 1)
+        .collect()
+}
