+    fn handle_visual_key(&mut self, key: UiKey) -> Vec<UiAction> {
+        match key {
+            UiKey::Esc => self.visual = None,
+            UiKey::Char('h') | UiKey::Left => self.visual_move_col(-1),
+            UiKey::Char('l') | UiKey::Right => self.visual_move_col(1),
+            UiKey::Char('j') | UiKey::Down => self.visual_move_row(1),
+            UiKey::Char('k') | UiKey::Up => self.visual_move_row(-1),
+            UiKey::Char('y') => self.visual_yank_current(),
+            UiKey::Char('Y') => self.visual_yank_lines(),
+            UiKey::Char('v') => self.visual_toggle_kind(VisualKind::Char),
+            UiKey::Char('V') => self.visual_toggle_kind(VisualKind::Line),
+            _ => {}
+        }
+        Vec::new()
+    }
+
+    fn visual_move_row(&mut self, delta: isize) {
+        if let Some(visual) = self.visual.as_mut() {
+            let max_row = visual.lines.len().saturating_sub(1) as isize;
+            let next = (visual.cursor.row as isize + delta).clamp(0, max_row);
+            visual.cursor.row = next as usize;
+            let line_len = visual
+                .lines
+                .get(visual.cursor.row)
+                .map(|line| line.chars().count())
+                .unwrap_or(0);
+            let max_col = line_len.saturating_sub(1);
+            if visual.cursor.col > max_col {
+                visual.cursor.col = max_col;
+            }
+        }
+    }
+
+    fn visual_move_col(&mut self, delta: isize) {
+        if let Some(visual) = self.visual.as_mut() {
+            let line_len = visual
+                .lines
+                .get(visual.cursor.row)
+                .map(|line| line.chars().count())
+                .unwrap_or(0);
+            let max_col = line_len.saturating_sub(1) as isize;
+            let next = (visual.cursor.col as isize + delta).clamp(0, max_col);
+            visual.cursor.col = next as usize;
+        }
+    }
+
+    fn visual_yank_current(&mut self) {
+        if let Some(visual) = self.visual.take() {
+            self.visual_yank = Some(self.visual_selection_text(&visual));
+        }
+    }
+
+    fn visual_yank_lines(&mut self) {
+        if let Some(visual) = self.visual.take() {
+            self.visual_yank = Some(self.visual_linewise_text(&visual));
+        }
+    }
+
+    fn visual_selection_text(&self, visual: &VisualState) -> String {
+        match visual.kind {
+            VisualKind::Char => self.visual_charwise_text(visual),
+            VisualKind::Line => self.visual_linewise_text(visual),
+            VisualKind::Block => self.visual_blockwise_text(visual),
+        }
+    }
+
+    fn visual_charwise_text(&self, visual: &VisualState) -> String {
+        let (start, end) = reading_order(visual.anchor, visual.cursor);
+        let mut text = String::new();
+        for row in start.row..=end.row {
+            let line = visual.lines.get(row).map(String::as_str).unwrap_or("");
+            let len = line.chars().count();
+            if len > 0 {
+                let (lo, hi) = charwise_columns(start, end, row, len);
+                text.push_str(&char_slice(line, lo, hi));
+            }
+            if row != end.row {
+                text.push('\n');
+            }
+        }
+        text
+    }
+
+    fn visual_linewise_text(&self, visual: &VisualState) -> String {
+        let lo = visual.anchor.row.min(visual.cursor.row);
+        let hi = visual.anchor.row.max(visual.cursor.row);
+        (lo..=hi)
+            .filter_map(|row| visual.lines.get(row).cloned())
+            .collect::<Vec<_>>()
+            .join("\n")
+    }
+
+    fn visual_blockwise_text(&self, visual: &VisualState) -> String {
+        let row_lo = visual.anchor.row.min(visual.cursor.row);
+        let row_hi = visual.anchor.row.max(visual.cursor.row);
+        let col_lo = visual.anchor.col.min(visual.cursor.col);
+        let col_hi = visual.anchor.col.max(visual.cursor.col);
+        (row_lo..=row_hi)
+            .map(|row| {
+                let line = visual.lines.get(row).map(String::as_str).unwrap_or("");
+                let len = line.chars().count();
+                if col_lo >= len {
+                    String::new()
+                } else {
+                    char_slice(line, col_lo, col_hi.min(len.saturating_sub(1)))
+                }
+            })
+            .collect::<Vec<_>>()
+            .join("\n")
+    }
+
+    fn visual_cells(&self, visual: &VisualState) -> Vec<(usize, usize)> {
+        let mut cells = Vec::new();
+        match visual.kind {
+            VisualKind::Char => {
+                let (start, end) = reading_order(visual.anchor, visual.cursor);
+                for row in start.row..=end.row {
+                    let len = visual
+                        .lines
+                        .get(row)
+                        .map(|line| line.chars().count())
+                        .unwrap_or(0);
+                    if len == 0 {
+                        continue;
+                    }
+                    let (lo, hi) = charwise_columns(start, end, row, len);
+                    for col in lo..=hi {
+                        cells.push((row, col));
+                    }
+                }
+            }
+            VisualKind::Line => {
+                let row_lo = visual.anchor.row.min(visual.cursor.row);
+                let row_hi = visual.anchor.row.max(visual.cursor.row);
+                for row in row_lo..=row_hi {
+                    let len = visual
+                        .lines
+                        .get(row)
+                        .map(|line| line.chars().count())
+                        .unwrap_or(0);
+                    for col in 0..len {
+                        cells.push((row, col));
+                    }
+                }
+            }
+            VisualKind::Block => {
+                let row_lo = visual.anchor.row.min(visual.cursor.row);
+                let row_hi = visual.anchor.row.max(visual.cursor.row);
+                let col_lo = visual.anchor.col.min(visual.cursor.col);
+                let col_hi = visual.anchor.col.max(visual.cursor.col);
+                for row in row_lo..=row_hi {
+                    let len = visual
+                        .lines
+                        .get(row)
+                        .map(|line| line.chars().count())
+                        .unwrap_or(0);
+                    if col_lo >= len {
+                        continue;
+                    }
+                    for col in col_lo..=col_hi.min(len.saturating_sub(1)) {
+                        cells.push((row, col));
+                    }
+                }
+            }
+        }
+        cells
+    }
+
+    fn apply_visual_highlight(&self, buffer: &mut Buffer) {
+        let Some(visual) = self.visual.as_ref() else {
+            return;
+        };
+        let layout = self.layout();
+        let (base_column, inner_width, inner_height) = match visual.pane {
+            PaneFocus::Right => {
+                let (inner_width, inner_height) = self.right_inner_size();
+                (
+                    layout.left_width.saturating_add(1),
+                    inner_width,
+                    inner_height,
+                )
+            }
+            PaneFocus::Left => {
+                if layout.left_width == 0 {
+                    return;
+                }
+                let inner_width = layout.left_width.saturating_sub(2).max(1);
+                let body_height = self.height.saturating_sub(1);
+                let inner_height = body_height.saturating_sub(2).max(1);
+                (1, inner_width, inner_height)
+            }
+        };
+        for (row, col) in self.visual_cells(visual) {
+            if row >= usize::from(inner_height) || col >= usize::from(inner_width) {
+                continue;
+            }
+            let x = base_column.saturating_add(col as u16);
+            let y = 1_u16.saturating_add(row as u16);
+            if x < buffer.area.width && y < buffer.area.height {
+                buffer.get_mut(x, y).modifier.insert(Modifier::REVERSED);
+            }
+        }
+    }
 }
 
