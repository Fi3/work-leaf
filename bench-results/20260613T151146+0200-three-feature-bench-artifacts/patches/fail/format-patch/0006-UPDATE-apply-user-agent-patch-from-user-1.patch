+    pub(crate) fn enter_visual(&mut self, kind: VisualKind, right_content: &str) {
+        if self.mode == UiMode::Prompt {
+            return;
+        }
+        let lines = match self.focus {
+            PaneFocus::Left => {
+                if !self.left_visible {
+                    return;
+                }
+                self.left_pane_rows()
+                    .into_iter()
+                    .map(|(text, _)| text)
+                    .collect()
+            }
+            PaneFocus::Right => self
+                .visible_right_content(right_content)
+                .lines()
+                .map(|line| line.to_string())
+                .collect(),
+        };
+        let cursor = CellPos::default();
+        self.visual = Some(VisualState {
+            kind,
+            pane: self.focus,
+            anchor: cursor,
+            cursor,
+            lines,
+        });
+    }
