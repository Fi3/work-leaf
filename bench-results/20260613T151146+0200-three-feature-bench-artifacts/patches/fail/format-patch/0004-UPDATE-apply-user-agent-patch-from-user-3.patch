+#[test]
+fn controller_prompts_feature_done_after_review_then_closes_and_reopens() {
+    let root = git_repo("workspace-feature-done-confirmation");
+    fs::write(root.join("README.md"), "before\n").unwrap();
+    git(&root, ["add", "README.md"]);
+    git(&root, ["commit", "-m", "ADD initial readme fixture"]);
+    let backend = FakeBackend::new([
+        "implemented patch\n@work-leaf patch update readme\n--- a/README.md\n+++ b/README.md\n@@ -1 +1 @@\n-before\n+after\n@work-leaf end\n@work-leaf done",
+        "summary: README change",
+        "NO_FINDINGS",
+        "reopened work reply",
+    ]);
+    let chat = CommandChat::new(root, backend).with_max_review_rounds(4);
+    let mut controller = WorkLeafController::new(chat);
+
+    let agent_id = controller.create_agent("update readme").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(2)));
+
+    assert_eq!(
+        controller.session_closure(&agent_id),
+        Some(SessionClosure::AwaitingDone)
+    );
+    let prompted = controller.snapshot();
+    let prompted_session = prompted.session(&agent_id).expect("patch agent session");
+    assert!(
+        prompted_session
+            .lines
+            .iter()
+            .any(|line| line.contains("is this feature done? (yes/no)"))
+    );
+
+    controller.send_message(&agent_id, "yes").unwrap();
+    assert_eq!(
+        controller.session_closure(&agent_id),
+        Some(SessionClosure::Closed)
+    );
+    let closed = controller.snapshot();
+    let closed_session = closed.session(&agent_id).expect("patch agent session");
+    assert!(
+        closed_session
+            .lines
+            .iter()
+            .any(|line| line.contains("feature marked done"))
+    );
+
+    controller
+        .send_message(&agent_id, "now add another section")
+        .unwrap();
+    assert_eq!(controller.session_closure(&agent_id), None);
+    assert!(controller.wait_for_idle(Duration::from_secs(2)));
+    let reopened = controller.snapshot();
+    let reopened_session = reopened.session(&agent_id).expect("patch agent session");
+    assert!(
+        reopened_session
+            .lines
+            .iter()
+            .any(|line| line == "user: now add another section")
+    );
+}
