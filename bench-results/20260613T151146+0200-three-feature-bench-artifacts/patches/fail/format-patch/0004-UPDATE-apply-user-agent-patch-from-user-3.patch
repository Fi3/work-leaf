+    fn set_session_closure(&mut self, agent_id: &AgentId, closure: Option<SessionClosure>) {
+        match closure {
+            Some(closure) => {
+                self.session_closures.insert(agent_id.clone(), closure);
+            }
+            None => {
+                self.session_closures.remove(agent_id);
+            }
+        }
+        self.pending_events.push(WorkLeafEvent::AgentClosureUpdated {
+            agent_id: agent_id.clone(),
+            closure,
+        });
+    }
+
+    fn prompt_feature_done(&mut self, agent_id: &AgentId) {
+        self.set_session_closure(agent_id, Some(SessionClosure::AwaitingDone));
+        self.append_agent_line(agent_id, FEATURE_DONE_QUESTION.to_string());
+        self.pending_events.push(WorkLeafEvent::AgentSelected {
+            agent_id: agent_id.clone(),
+        });
+    }
+
+    fn handle_feature_done_answer(
+        &mut self,
+        agent_id: &AgentId,
+        closure: SessionClosure,
+        message: &str,
+    ) -> bool {
+        let answer = message.trim().to_ascii_lowercase();
+        match closure {
+            SessionClosure::AwaitingDone => {
+                if matches!(answer.as_str(), "yes" | "y") {
+                    self.set_session_closure(agent_id, Some(SessionClosure::Closed));
+                    self.append_agent_line(
+                        agent_id,
+                        "work-leaf: feature marked done; chat closed".to_string(),
+                    );
+                    return true;
+                }
+                if matches!(answer.as_str(), "no" | "n") {
+                    self.set_session_closure(agent_id, None);
+                    self.append_agent_line(agent_id, "work-leaf: feature kept open".to_string());
+                    return true;
+                }
+                self.set_session_closure(agent_id, None);
+                false
+            }
+            SessionClosure::Closed => {
+                self.set_session_closure(agent_id, None);
+                self.append_agent_line(agent_id, "work-leaf: feature reopened".to_string());
+                false
+            }
+        }
+    }
