+
+#[test]
+fn scripted_harness_visual_char_selection_yanks_focused_right_pane_text() {
+    let mut harness = UiHarness::new(80, 24);
+    harness.handle_bytes(&[23, b'l']);
+    harness.handle_byte(b'v');
+    assert!(harness.ui().is_visual());
+
+    harness.handle_byte(b'l');
+    harness.handle_byte(b'y');
+
+    assert!(!harness.ui().is_visual());
+    assert_eq!(harness.ui().visual_yank(), Some("UI"));
+}
+
+#[test]
+fn scripted_harness_visual_line_selection_yanks_whole_line() {
+    let mut harness = UiHarness::new(80, 24);
+    harness.handle_bytes(&[23, b'l']);
+    harness.handle_byte(b'V');
+    harness.handle_byte(b'y');
+
+    assert_eq!(harness.ui().visual_yank(), Some("UI harness"));
+}
+
+#[test]
+fn scripted_harness_visual_block_selection_yanks_rectangle() {
+    let mut harness = UiHarness::new(80, 24);
+    harness.handle_bytes(&[23, b'l']);
+    harness.handle_byte(22);
+    assert!(harness.ui().is_visual());
+
+    harness.handle_byte(b'j');
+    harness.handle_byte(b'l');
+    harness.handle_byte(b'y');
+
+    assert_eq!(harness.ui().visual_yank(), Some("UI\nEs"));
+}
+
+#[test]
+fn scripted_harness_visual_selection_highlights_focused_text() {
+    let mut harness = UiHarness::new(80, 24);
+    harness.handle_bytes(&[23, b'l']);
+    harness.handle_byte(b'v');
+    harness.handle_byte(b'l');
+
+    assert!(harness.render_frame().contains("\u{1b}[7mUI\u{1b}[0m"));
+}
+
+#[test]
+fn scripted_harness_visual_line_selection_works_in_left_pane() {
+    let mut harness = UiHarness::new(80, 24);
+    assert_eq!(harness.ui().focus(), PaneFocus::Left);
+
+    harness.handle_byte(b'V');
+    assert!(harness.ui().is_visual());
+    harness.handle_byte(b'y');
+
+    assert_eq!(harness.ui().visual_yank(), Some("  work-leaf  command"));
+}
+
+#[test]
+fn scripted_harness_visual_mode_status_shows_visual() {
+    let mut harness = UiHarness::new(80, 24);
+    harness.handle_byte(b'v');
+
+    assert!(harness.ui().is_visual());
+    assert!(harness.render_frame().contains("mode=visual focus=left"));
+}
+
+#[test]
+fn scripted_harness_visual_escape_exits_without_yank() {
+    let mut harness = UiHarness::new(80, 24);
+    harness.handle_bytes(&[23, b'l']);
+    harness.handle_byte(b'v');
+    assert!(harness.ui().is_visual());
+
+    harness.handle_byte(27);
+
+    assert!(!harness.ui().is_visual());
+    assert_eq!(harness.ui().visual_yank(), None);
+}
