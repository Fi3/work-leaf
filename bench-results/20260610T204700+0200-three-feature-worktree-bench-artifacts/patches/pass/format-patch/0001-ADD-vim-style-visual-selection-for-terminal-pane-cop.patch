 src/ui_harness.rs     |  48 ++-
 tests/terminal_app.rs |  59 +++
 tests/terminal_ui.rs  |  17 +
 tests/ui_harness.rs   |  47 +++
 8 files changed, 987 insertions(+), 97 deletions(-)

