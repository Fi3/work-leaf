+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct BackendCommand<'a> {
+    token: &'a str,
+    args: &'a str,
+}
+
+fn parse_backend_command(command: &str) -> Option<BackendCommand<'_>> {
+    let rest = command.trim().strip_prefix('/')?;
+    let token_end = rest.find(char::is_whitespace).unwrap_or(rest.len());
+    let token = &rest[..token_end];
+    if token.is_empty() {
+        return None;
+    }
+    Some(BackendCommand {
+        token,
+        args: rest[token_end..].trim(),
+    })
+}
+
+fn unsupported_backend_command(agent_id: &AgentId, command: &str) -> AgentError {
+    let command = parse_backend_command(command)
+        .map(|command| format!("/{}", command.token))
+        .unwrap_or_else(|| command.to_string());
+    AgentError::UnsupportedAgentCommand {
+        agent_id: agent_id.clone(),
+        command,
+    }
 }
 
