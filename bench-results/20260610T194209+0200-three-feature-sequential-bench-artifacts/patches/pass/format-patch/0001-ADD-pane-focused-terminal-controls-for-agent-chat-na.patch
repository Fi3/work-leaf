+fn ordered_rows(first: usize, second: usize) -> (usize, usize) {
+    if first <= second {
+        (first, second)
+    } else {
+        (second, first)
+    }
+}
+
+fn ordered_positions(first: TextPosition, second: TextPosition) -> (TextPosition, TextPosition) {
+    if (first.row, first.column) <= (second.row, second.column) {
+        (first, second)
+    } else {
+        (second, first)
+    }
+}
+
+fn char_slice(text: &str, start: usize, end: usize) -> String {
+    text.chars()
+        .skip(start)
+        .take(end.saturating_sub(start))
+        .collect()
+}
