+#[test]
+fn codex_backend_status_command_reports_selected_session_state() {
+    let config = CodexCommandConfig::new(PathBuf::from("/repo")).with_binary("codex");
+    let mut backend = CodexBackend::new(config, PromptPolicy::for_restricted_agents());
+    let agent_id = AgentId::new("chat-a").unwrap();
+    backend
+        .record_launch_output(
+            AgentLaunch::new(
+                agent_id.clone(),
+                AgentKind::Codex,
+                "parser",
+                "implement parser",
+            ),
+            r#"{"type":"thread.started","thread_id":"thread-123"}"#.to_string()
+                + "\n"
+                + r#"{"type":"item.completed","item":{"type":"agent_message","text":"ready"}}"#,
+        )
+        .unwrap();
+
+    let reply = backend.command(&agent_id, "status", "").unwrap();
+
+    assert!(reply.text.contains("Codex session status"));
+    assert!(reply.text.contains("agent: chat-a"));
+    assert!(reply.text.contains("thread: thread-123"));
+    assert!(reply.text.contains("feature: parser"));
+    assert!(reply.text.contains("state: idle"));
+    let session = backend.session(&agent_id).unwrap();
+    assert_eq!(
+        session.messages[session.messages.len() - 2].role,
+        MessageRole::User
+    );
+    assert_eq!(session.messages[session.messages.len() - 2].text, "/status");
+    assert_eq!(session.messages.last().unwrap().text, reply.text);
+}
