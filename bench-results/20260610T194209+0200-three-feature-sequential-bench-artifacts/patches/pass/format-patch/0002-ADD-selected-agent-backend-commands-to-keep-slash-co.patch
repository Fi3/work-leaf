+#[test]
+fn controller_routes_status_slash_command_while_selected_agent_is_busy() {
+    let backend = BusyCommandBackend::default();
+    let chat = CommandChat::new(PathBuf::from("/repo"), backend.clone());
+    let mut controller = WorkLeafController::new(chat);
+
+    let agent_id = controller.create_agent("").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+
+    controller.send_message(&agent_id, "slow question").unwrap();
+    assert_eq!(
+        controller
+            .snapshot()
+            .session(&agent_id)
+            .expect("session exists")
+            .loading,
+        Some(WorkLeafLoading::WaitingForReply)
+    );
+
+    controller.send_message(&agent_id, "/status").unwrap();
+
+    let snapshot = controller.snapshot();
+    let session = snapshot.session(&agent_id).expect("session exists");
+    assert!(session.lines.iter().any(|line| line == "user: /status"));
+    assert!(session.lines.iter().any(|line| line == "status while busy"));
+    assert!(
+        !session
+            .lines
+            .iter()
+            .any(|line| line.contains("still working"))
+    );
+    assert_eq!(session.loading, Some(WorkLeafLoading::WaitingForReply));
+    assert_eq!(
+        backend.commands(),
+        vec![(agent_id.clone(), "status".to_string(), String::new())]
+    );
+    assert!(
+        !backend
+            .sends()
+            .iter()
+            .any(|(_, prompt)| prompt == "/status"),
+        "/status must not be delivered through the normal backend send path"
+    );
+
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+    let snapshot = controller.snapshot();
+    let session = snapshot.session(&agent_id).expect("session exists");
+    assert!(session.lines.iter().any(|line| line == "slow reply"));
+    assert_eq!(session.loading, None);
+}
