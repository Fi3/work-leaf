+const FEATURE_DONE_PROMPT: &str = "work-leaf: is this feature done? yes/no";
+const FEATURE_DONE_CLOSED: &str = "work-leaf: feature marked done";
+const FEATURE_DONE_OPEN: &str = "work-leaf: feature remains open";
+const FEATURE_DONE_REOPENED: &str = "work-leaf: feature reopened";
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+enum FeatureDonePromptState {
+    AwaitingAnswer,
+    Closed,
+}
+
+pub(crate) fn session_awaits_feature_done(session: &WorkLeafSession) -> bool {
+    let mut awaiting = false;
+    for line in &session.lines {
+        match line.as_str() {
+            FEATURE_DONE_PROMPT => awaiting = true,
+            FEATURE_DONE_CLOSED | FEATURE_DONE_OPEN | FEATURE_DONE_REOPENED => awaiting = false,
+            _ => {}
+        }
+    }
+    awaiting
+}
+
+fn is_yes_answer(message: &str) -> bool {
+    matches!(message.trim().to_ascii_lowercase().as_str(), "yes" | "y")
+}
+
+fn is_no_answer(message: &str) -> bool {
+    matches!(message.trim().to_ascii_lowercase().as_str(), "no" | "n")
+}
