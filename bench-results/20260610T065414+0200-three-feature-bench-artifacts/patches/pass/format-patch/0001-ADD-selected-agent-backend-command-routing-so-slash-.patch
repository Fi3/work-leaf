 src/agent_runtime.rs  |  23 ++++++-
 src/cli.rs            |  33 ++++++++++
 src/codex.rs          | 143 ++++++++++++++++++++++++++---------------
 src/workspace.rs      | 146 +++++++++++++++++++++++++++++++++++++++++-
 tests/terminal_app.rs |  34 +++++++++-
 6 files changed, 332 insertions(+), 62 deletions(-)

