+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::agent::{AgentError, AgentSession, ChatMessage, MessageRole};
+    use std::sync::{Arc, Mutex};
+
+    #[test]
+    fn selected_agent_status_slash_command_runs_backend_command_without_normal_send() {
+        let (mut controller, records) = controller_with_recording_backend();
+        let agent_id = controller
+            .create_agent("initial work")
+            .expect("agent launch is prepared");
+        assert!(controller.wait_for_idle(Duration::from_secs(2)));
+
+        controller
+            .send_message(&agent_id, "/status")
+            .expect("slash command is accepted");
+
+        assert!(controller.wait_for_session_line(
+            &agent_id,
+            "backend command output for /status",
+            Duration::from_secs(2)
+        ));
+        let records = records
+            .lock()
+            .expect("recording backend state is available");
+        assert_eq!(
+            records.commands,
+            vec![(agent_id.as_str().to_string(), "/status".to_string())]
+        );
+        assert!(
+            !records.sends.iter().any(|(_, prompt)| prompt == "/status"),
+            "/status must not be routed through the normal backend send path"
+        );
+
+        let session = controller
+            .snapshot()
+            .session(&agent_id)
+            .expect("agent session exists")
+            .clone();
+        assert!(session.lines.iter().any(|line| line == "user: /status"));
+        assert!(
+            session
+                .lines
+                .iter()
+                .any(|line| line == "backend command output for /status")
+        );
+    }
+
+    #[test]
+    fn selected_agent_fork_slash_command_runs_backend_command() {
+        let (mut controller, records) = controller_with_recording_backend();
+        let agent_id = controller
+            .create_agent("initial work")
+            .expect("agent launch is prepared");
+        assert!(controller.wait_for_idle(Duration::from_secs(2)));
+
+        controller
+            .send_message(&agent_id, "/fork")
+            .expect("slash command is accepted");
+
+        assert!(controller.wait_for_session_line(
+            &agent_id,
+            "backend command output for /fork",
+            Duration::from_secs(2)
+        ));
+        let records = records
+            .lock()
+            .expect("recording backend state is available");
+        assert_eq!(
+            records.commands,
+            vec![(agent_id.as_str().to_string(), "/fork".to_string())]
+        );
+    }
+
+    fn controller_with_recording_backend() -> (
+        WorkLeafController<RecordingBackend>,
+        Arc<Mutex<RecordingBackendRecords>>,
+    ) {
+        let backend = RecordingBackend::default();
+        let records = backend.records.clone();
+        let chat = CommandChat::new(std::env::current_dir().unwrap(), backend);
+        (WorkLeafController::new(chat), records)
+    }
+
+    #[derive(Clone, Default)]
+    struct RecordingBackend {
+        records: Arc<Mutex<RecordingBackendRecords>>,
+    }
+
+    #[derive(Clone, Debug, Default, Eq, PartialEq)]
+    struct RecordingBackendRecords {
+        launches: Vec<(String, String)>,
+        sends: Vec<(String, String)>,
+        commands: Vec<(String, String)>,
+    }
+
+    impl AgentBackend for RecordingBackend {
+        fn launch(&mut self, request: AgentLaunch) -> Result<AgentSession, AgentError> {
+            self.records
+                .lock()
+                .expect("recording backend state is available")
+                .launches
+                .push((request.id.as_str().to_string(), request.prompt.clone()));
+            let mut session = AgentSession::new(request);
+            session.push_message(MessageRole::Agent, "launch reply");
+            Ok(session)
+        }
+
+        fn send(&mut self, agent_id: &AgentId, prompt: &str) -> Result<ChatMessage, AgentError> {
+            self.records
+                .lock()
+                .expect("recording backend state is available")
+                .sends
+                .push((agent_id.as_str().to_string(), prompt.to_string()));
+            Ok(ChatMessage::new(MessageRole::Agent, "send reply"))
+        }
+
+        fn run_command(
+            &mut self,
+            agent_id: &AgentId,
+            command: &str,
+        ) -> Result<ChatMessage, AgentError> {
+            self.records
+                .lock()
+                .expect("recording backend state is available")
+                .commands
+                .push((agent_id.as_str().to_string(), command.to_string()));
+            Ok(ChatMessage::new(
+                MessageRole::Agent,
+                format!("backend command output for {command}"),
+            ))
+        }
+    }
+}
