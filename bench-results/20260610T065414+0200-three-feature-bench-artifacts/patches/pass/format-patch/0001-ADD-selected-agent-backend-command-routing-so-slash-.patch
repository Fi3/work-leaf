+pub(crate) fn agent_backend_command(message: &str) -> Option<&str> {
+    let command = message.strip_prefix('/')?;
+    let first = command.chars().next()?;
+    if first.is_whitespace() {
+        None
+    } else {
+        Some(message)
+    }
