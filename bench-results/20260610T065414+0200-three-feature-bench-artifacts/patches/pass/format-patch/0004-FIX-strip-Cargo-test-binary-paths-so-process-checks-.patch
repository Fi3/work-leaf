+fn is_work_leaf_binary_arg(arg: &str) -> bool {
+    let file_name = Path::new(arg)
+        .file_name()
+        .and_then(|name| name.to_str())
+        .unwrap_or(arg);
+    let file_name = file_name.strip_suffix(".exe").unwrap_or(file_name);
+    file_name == "work-leaf"
+        || file_name.starts_with("work-leaf-")
+        || file_name.starts_with("work_leaf-")
+}
