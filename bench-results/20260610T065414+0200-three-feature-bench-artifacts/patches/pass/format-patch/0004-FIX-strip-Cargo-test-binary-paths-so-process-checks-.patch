     let command = match parse_process_args(env::args()) {
         Ok(command) => command,
@@ -219,12 +230,24 @@ impl Drop for ManagedOrchestrator {
 
 fn orchestrator_binary_path() -> Result<PathBuf, CliError> {
     let exe = env::current_exe()?;
+    Ok(orchestrator_binary_path_for_exe(&exe))
+}
+
+fn orchestrator_binary_path_for_exe(exe: &Path) -> PathBuf {
     let name = if cfg!(windows) {
         "work-leaf-orchestrator.exe"
     } else {
         "work-leaf-orchestrator"
     };
-    Ok(exe.with_file_name(name))
+    let Some(parent) = exe.parent() else {
+        return PathBuf::from(name);
+    };
+    if parent.file_name().and_then(|part| part.to_str()) == Some("deps")
+        && let Some(target_dir) = parent.parent()
+    {
+        return target_dir.join(name);
+    }
+    exe.with_file_name(name)
 }
 
