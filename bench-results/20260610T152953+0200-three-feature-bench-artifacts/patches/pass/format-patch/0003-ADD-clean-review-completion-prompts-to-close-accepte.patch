+#[test]
+fn review_coordinator_accepts_no_findings_after_reviewer_status_text() {
+    let root = git_repo("review-status-preface");
+    fs::write(root.join("README.md"), "after\n").unwrap();
+    git(&root, ["add", "."]);
+    git(
+        &root,
+        [
+            "commit",
+            "-m",
+            "UPDATE apply readme patch from user-1",
+            "-m",
+            "Agent-ID: user-1\nFeature: readme\nReason: update fixture",
+        ],
+    );
+
+    let backend = FakeBackend::new([
+        "summary: README changes",
+        "I checked the patch.\nNO_FINDINGS\n@work-leaf done",
+    ]);
+    let mut coordinator = ReviewCoordinator::new(root, backend).with_max_rounds(4);
+
+    let results = coordinator.review_latest_agent_commits().unwrap();
+
+    assert_eq!(results.len(), 1);
+    assert!(results[0].findings_resolved);
+    assert_eq!(results[0].rounds, 1);
+}
+
+#[test]
+fn review_coordinator_does_not_let_later_no_findings_override_findings_marker() {
+    let root = git_repo("review-contradictory-marker");
+    fs::write(root.join("README.md"), "after\n").unwrap();
+    git(&root, ["add", "."]);
+    git(
+        &root,
+        [
+            "commit",
+            "-m",
+            "UPDATE apply readme patch from user-1",
+            "-m",
+            "Agent-ID: user-1\nFeature: readme\nReason: update fixture",
+        ],
+    );
+
+    let backend = FakeBackend::new([
+        "summary: README changes",
+        "FINDINGS\n- missing verification\nNO_FINDINGS",
+        "fixed missing verification",
+        "NO_FINDINGS",
+    ]);
+    let mut coordinator = ReviewCoordinator::new(root, backend).with_max_rounds(4);
+
+    let results = coordinator.review_latest_agent_commits().unwrap();
+    let backend = coordinator.into_backend();
+
+    assert_eq!(results.len(), 1);
+    assert!(results[0].findings_resolved);
+    assert_eq!(results[0].rounds, 2);
+    assert_eq!(backend.sends[1].0.as_str(), "user-1");
+    assert!(backend.sends[1].1.contains("missing verification"));
+}
