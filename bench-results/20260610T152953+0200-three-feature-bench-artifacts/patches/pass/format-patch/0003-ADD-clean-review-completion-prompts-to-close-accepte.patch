+#[test]
+fn scripted_harness_feature_done_prompt_closes_on_yes_and_reopens_on_typing() {
+    let mut harness = UiHarness::new(100, 24);
+
+    harness
+        .ask_feature_done("user-1")
+        .expect("fixture user-1 agent is registered");
+
+    let prompt_frame = harness.render_frame();
+    assert!(prompt_frame.starts_with('\u{7}'));
+    assert!(prompt_frame.contains("work-leaf: is this feature done? yes/no"));
+
+    harness.handle_bytes(b"yes\n");
+
+    assert!(
+        harness
+            .transcript()
+            .iter()
+            .any(|line| line == "work-leaf: feature closed")
+    );
+    assert!(harness.ui().selected_agent().is_none());
+    assert!(
+        !harness
+            .ui()
+            .render_left_pane()
+            .contains("parser user-1  working: parser")
+    );
+
+    let mut harness = UiHarness::new(100, 24);
+    harness
+        .ask_feature_done("user-1")
+        .expect("fixture user-1 agent is registered");
+
+    harness.handle_bytes(b"keep going\n");
+
+    let left_pane = harness.ui().render_left_pane();
+    assert!(left_pane.contains(">parser user-1  working: parser"));
+    assert!(
+        harness
+            .transcript()
+            .iter()
+            .any(|line| line == "work-leaf: feature reopened")
+    );
+    assert!(
+        harness
+            .transcript()
+            .iter()
+            .any(|line| line == "user-1> keep going")
+    );
+
+    harness
+        .ask_feature_done("user-1")
+        .expect("fixture user-1 agent is registered");
+    let repeated_prompt_frame = harness.render_frame();
+    assert!(repeated_prompt_frame.contains("work-leaf: is this feature done? yes/no"));
+
+    harness.handle_bytes(b"no\n");
+
+    assert_eq!(
+        harness
+            .transcript()
+            .iter()
+            .filter(|line| line.as_str() == "work-leaf: feature reopened")
+            .count(),
+        2
+    );
+}
