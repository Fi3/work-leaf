+fn feature_completion_prompts_from_snapshot(snapshot: &WorkLeafSnapshot) -> BTreeSet<AgentId> {
+    snapshot
+        .sessions
+        .iter()
+        .filter(|session| session_feature_completion_pending(session))
+        .map(|session| session.id.clone())
+        .collect()
+}
+
+fn session_feature_completion_pending(session: &WorkLeafSession) -> bool {
+    session
+        .lines
+        .iter()
+        .rev()
+        .find_map(|line| {
+            if is_feature_done_prompt(line) {
+                Some(true)
+            } else if is_feature_completion_resolution(line) {
+                Some(false)
+            } else {
+                None
+            }
+        })
+        .unwrap_or(false)
+}
+
+fn is_feature_done_prompt(line: &str) -> bool {
+    line.starts_with(FEATURE_DONE_PROMPT)
+}
+
+fn is_feature_completion_resolution(line: &str) -> bool {
+    line == FEATURE_CLOSED_LINE || line == FEATURE_REOPENED_LINE
+}
+
+fn is_feature_completion_yes(message: &str) -> bool {
+    matches!(message.trim().to_ascii_lowercase().as_str(), "yes" | "y")
+}
