 src/terminal_app.rs   |  65 ++++-
 src/ui.rs             | 608 +++++++++++++++++++++++++++++++++++++++---
 src/ui_harness.rs     |  68 ++++-
 tests/terminal_app.rs |  16 ++
 tests/ui_harness.rs   |  69 +++++
 6 files changed, 775 insertions(+), 55 deletions(-)

