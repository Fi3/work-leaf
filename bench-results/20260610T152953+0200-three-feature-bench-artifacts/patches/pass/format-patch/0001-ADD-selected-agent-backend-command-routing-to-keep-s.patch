+pub(crate) fn selected_agent_backend_command(message: &str) -> Option<&str> {
+    let message = message.trim();
+    let rest = message.strip_prefix('/')?;
+    let first = rest.chars().next()?;
+    if first.is_whitespace() {
+        return None;
+    }
+    Some(message)
+}
