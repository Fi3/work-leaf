+    fn handle_visual_key(&mut self, key: UiKey, right_content: &str) -> Vec<UiAction> {
+        match key {
+            UiKey::Esc => {
+                self.clear_visual_selection();
+            }
+            UiKey::Char('v') => self.set_visual_kind(VisualKind::Character, right_content),
+            UiKey::Char('V') => self.set_visual_kind(VisualKind::Line, right_content),
+            UiKey::Char('\u{16}') => self.set_visual_kind(VisualKind::Block, right_content),
+            UiKey::Char('h') | UiKey::Left => self.move_visual_cursor(0, -1, right_content),
+            UiKey::Char('j') | UiKey::Down => self.move_visual_cursor(1, 0, right_content),
+            UiKey::Char('k') | UiKey::Up => self.move_visual_cursor(-1, 0, right_content),
+            UiKey::Char('l') | UiKey::Right => self.move_visual_cursor(0, 1, right_content),
+            UiKey::Char('y') => self.copy_visual_selection(false, right_content),
+            UiKey::Char('Y') => self.copy_visual_selection(true, right_content),
+            _ => {}
+        }
+        Vec::new()
+    }
+
+    fn start_visual_selection(&mut self, kind: VisualKind, right_content: &str) {
+        let pane = self.focus;
+        let lines = self.pane_text_lines(pane, right_content);
+        let anchor = self.visual_start_position(pane, &lines);
+        self.visual_selection = Some(VisualSelection {
+            pane,
+            kind,
+            anchor,
+            cursor: anchor,
+        });
+    }
+
+    fn set_visual_kind(&mut self, kind: VisualKind, right_content: &str) {
+        if self.visual_selection.is_none() {
+            self.start_visual_selection(kind, right_content);
+            return;
+        }
+        let Some(mut selection) = self.visual_selection else {
+            return;
+        };
+        let lines = self.pane_text_lines(selection.pane, right_content);
+        selection.kind = kind;
+        selection.anchor = clamp_position(selection.anchor, &lines);
+        selection.cursor = clamp_position(selection.cursor, &lines);
+        self.visual_selection = Some(selection);
+    }
+
+    fn move_visual_cursor(&mut self, row_delta: isize, column_delta: isize, right_content: &str) {
+        let Some(mut selection) = self.visual_selection else {
+            return;
+        };
+        let lines = self.pane_text_lines(selection.pane, right_content);
+        if lines.is_empty() {
+            selection.cursor = TextPosition { row: 0, column: 0 };
+            self.visual_selection = Some(selection);
+            return;
+        }
+
+        let row = apply_delta(selection.cursor.row, row_delta, lines.len().saturating_sub(1));
+        let line_width = lines[row].chars().count().saturating_sub(1);
+        let column = apply_delta(selection.cursor.column, column_delta, line_width);
+        selection.cursor = TextPosition { row, column };
+        self.visual_selection = Some(selection);
+    }
+
+    fn copy_visual_selection(&mut self, force_linewise: bool, right_content: &str) {
+        let Some(selection) = self.visual_selection else {
+            return;
+        };
+        let lines = self.pane_text_lines(selection.pane, right_content);
+        let copied = selection_text(selection, &lines, force_linewise);
+        self.pending_clipboard.replace(Some(copied.clone()));
+        self.show_status_notice(
+            format!("copied {} chars", copied.chars().count()),
+            Duration::from_secs(STATUS_NOTICE_SECONDS),
+        );
+        self.clear_visual_selection();
+    }
+
+    fn clear_visual_selection(&mut self) {
+        self.visual_selection = None;
+    }
+
+    fn visual_selection_for_pane(&self, pane: PaneFocus) -> Option<VisualSelection> {
+        self.visual_selection
+            .filter(|selection| selection.pane == pane)
+    }
+
+    fn left_pane_lines(&self) -> Vec<LeftPaneLine> {
+        let inner_width = usize::from(self.layout().left_width.saturating_sub(2).max(1));
+        let mut lines = vec![LeftPaneLine {
+            text: if self.control_selected == 0 {
+                "> work-leaf  command".to_string()
