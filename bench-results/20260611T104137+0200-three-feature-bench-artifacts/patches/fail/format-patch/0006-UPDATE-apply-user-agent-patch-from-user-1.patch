+fn apply_delta(value: usize, delta: isize, max: usize) -> usize {
+    if delta < 0 {
+        value.saturating_sub(delta.unsigned_abs()).min(max)
+    } else {
+        value.saturating_add(delta as usize).min(max)
+    }
+}
+
+fn clamp_position(position: TextPosition, lines: &[String]) -> TextPosition {
+    if lines.is_empty() {
+        return TextPosition { row: 0, column: 0 };
+    }
+    let row = position.row.min(lines.len().saturating_sub(1));
+    let column = position
+        .column
+        .min(lines[row].chars().count().saturating_sub(1));
+    TextPosition { row, column }
+}
+
+fn selection_rows(selection: VisualSelection, line_count: usize) -> Option<(usize, usize)> {
+    if line_count == 0 {
+        return None;
+    }
+    let start = selection.anchor.row.min(selection.cursor.row);
+    let end = selection.anchor.row.max(selection.cursor.row);
+    Some((
+        start.min(line_count.saturating_sub(1)),
+        end.min(line_count.saturating_sub(1)),
+    ))
+}
+
+fn selection_range_for_line(
+    selection: VisualSelection,
+    row: usize,
+    line_width: usize,
+) -> Option<(usize, usize)> {
+    match selection.kind {
+        VisualKind::Line => {
+            let start_row = selection.anchor.row.min(selection.cursor.row);
+            let end_row = selection.anchor.row.max(selection.cursor.row);
+            (start_row..=end_row)
+                .contains(&row)
+                .then_some((0, line_width.max(1)))
+        }
+        VisualKind::Block => {
+            let start_row = selection.anchor.row.min(selection.cursor.row);
+            let end_row = selection.anchor.row.max(selection.cursor.row);
+            if !(start_row..=end_row).contains(&row) {
+                return None;
+            }
+            let start = selection.anchor.column.min(selection.cursor.column);
+            let end = selection.anchor.column.max(selection.cursor.column);
+            Some((
+                start.min(line_width),
+                end.saturating_add(1).min(line_width.max(1)),
+            ))
+        }
+        VisualKind::Character => {
+            let (start, end) = ordered_positions(selection.anchor, selection.cursor);
+            if row < start.row || row > end.row {
+                return None;
+            }
+            let range = if start.row == end.row {
+                (start.column, end.column.saturating_add(1))
+            } else if row == start.row {
+                (start.column, line_width)
+            } else if row == end.row {
+                (0, end.column.saturating_add(1))
+            } else {
+                (0, line_width)
+            };
+            Some((range.0.min(line_width), range.1.min(line_width.max(1))))
+        }
+    }
+}
+
+fn ordered_positions(left: TextPosition, right: TextPosition) -> (TextPosition, TextPosition) {
+    if (left.row, left.column) <= (right.row, right.column) {
+        (left, right)
+    } else {
+        (right, left)
+    }
+}
+
+fn line_spans(line: &str, range: Option<(usize, usize)>) -> Vec<Span<'static>> {
+    let Some((start, end)) = range else {
+        return vec![Span::raw(line.to_string())];
+    };
+    let line_width = line.chars().count();
+    if line_width == 0 && end > start {
+        return vec![Span::styled(
+            " ".to_string(),
+            Style::default().add_modifier(Modifier::REVERSED),
+        )];
+    }
+    if start >= line_width {
+        return vec![Span::raw(line.to_string())];
+    }
+
+    let end = end.min(line_width);
+    let mut spans = Vec::new();
+    let before = slice_chars(line, 0, start);
+    if !before.is_empty() {
+        spans.push(Span::raw(before));
+    }
+    let selected = slice_chars(line, start, end);
+    if !selected.is_empty() {
+        spans.push(Span::styled(
+            selected,
+            Style::default().add_modifier(Modifier::REVERSED),
+        ));
+    }
+    let after = slice_chars(line, end, line_width);
+    if !after.is_empty() {
+        spans.push(Span::raw(after));
+    }
+    spans
+}
+
+fn selection_text(selection: VisualSelection, lines: &[String], force_linewise: bool) -> String {
+    let Some((start_row, end_row)) = selection_rows(selection, lines.len()) else {
+        return String::new();
+    };
+    if force_linewise || selection.kind == VisualKind::Line {
+        return lines[start_row..=end_row].join("\n");
+    }
+
+    match selection.kind {
+        VisualKind::Line => lines[start_row..=end_row].join("\n"),
+        VisualKind::Block => {
+            let start = selection.anchor.column.min(selection.cursor.column);
+            let end = selection.anchor.column.max(selection.cursor.column);
+            lines[start_row..=end_row]
+                .iter()
+                .map(|line| slice_chars(line, start, end.saturating_add(1)))
+                .collect::<Vec<_>>()
+                .join("\n")
+        }
+        VisualKind::Character => {
+            let (start, end) = ordered_positions(selection.anchor, selection.cursor);
+            lines[start.row..=end.row]
+                .iter()
+                .enumerate()
+                .map(|(offset, line)| {
+                    let row = start.row + offset;
+                    let line_width = line.chars().count();
+                    let range = if start.row == end.row {
+                        (start.column, end.column.saturating_add(1))
+                    } else if row == start.row {
+                        (start.column, line_width)
+                    } else if row == end.row {
+                        (0, end.column.saturating_add(1))
+                    } else {
+                        (0, line_width)
+                    };
+                    slice_chars(line, range.0, range.1)
+                })
+                .collect::<Vec<_>>()
+                .join("\n")
+        }
+    }
+}
+
+fn slice_chars(text: &str, start: usize, end: usize) -> String {
+    text.chars()
+        .skip(start)
+        .take(end.saturating_sub(start))
+        .collect()
+}
+
+fn base64_encode(bytes: &[u8]) -> String {
+    const ALPHABET: &[u8; 64] =
+        b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
+    let mut encoded = String::with_capacity(bytes.len().div_ceil(3) * 4);
+    for chunk in bytes.chunks(3) {
+        let first = chunk[0];
+        let second = *chunk.get(1).unwrap_or(&0);
+        let third = *chunk.get(2).unwrap_or(&0);
+
+        encoded.push(ALPHABET[(first >> 2) as usize] as char);
+        encoded.push(ALPHABET[(((first & 0b0000_0011) << 4) | (second >> 4)) as usize] as char);
+        if chunk.len() > 1 {
+            encoded.push(ALPHABET[(((second & 0b0000_1111) << 2) | (third >> 6)) as usize] as char);
+        } else {
+            encoded.push('=');
+        }
+        if chunk.len() > 2 {
+            encoded.push(ALPHABET[(third & 0b0011_1111) as usize] as char);
+        } else {
+            encoded.push('=');
+        }
+    }
+    encoded
+}
