+#[test]
+fn scripted_harness_review_completion_prompt_closes_or_reopens_patch_chat() {
+    let mut harness = UiHarness::new(100, 24);
+
+    harness
+        .mark_agent_review_complete("user-1")
+        .expect("fixture user-1 agent is registered");
+
+    let prompt_frame = harness.render_frame();
+    assert!(prompt_frame.starts_with('\u{7}'));
+    assert!(prompt_frame.contains("work-leaf: is this feature done? yes/no"));
+
+    harness.handle_bytes(b"yes\n");
+
+    assert!(harness.ui().selected_agent().is_none());
+    assert!(
+        !harness
+            .ui()
+            .render_left_pane()
+            .contains("parser user-1  working: parser")
+    );
+
+    let mut reopen = UiHarness::new(100, 24);
+    reopen
+        .mark_agent_review_complete("user-1")
+        .expect("fixture user-1 agent is registered");
+    reopen.handle_bytes(b"no, continue\n");
+
+    assert_eq!(
+        reopen.ui().selected_agent().map(|agent_id| agent_id.as_str()),
+        Some("user-1")
+    );
+    assert!(
+        reopen
+            .ui()
+            .render_left_pane()
+            .contains("parser user-1  working: parser")
+    );
+    assert!(
+        reopen
+            .transcript()
+            .iter()
+            .any(|line| line == "user-1> no, continue")
+    );
+    assert!(
+        !reopen
+            .render_frame()
+            .contains("work-leaf: is this feature done? yes/no")
+    );
+}
