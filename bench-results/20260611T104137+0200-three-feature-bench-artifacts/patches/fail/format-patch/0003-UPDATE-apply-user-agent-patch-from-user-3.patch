+        let Some(agent) = self.agents.iter_mut().find(|agent| &agent.id == agent_id) else {
+            return Err(format!("unknown agent `{agent_id}`"));
+        };
+        agent.hidden = false;
+        agent.ready = true;
+        self.pending_bell.set(true);
+        Ok(())
