+            PaneFocus::Left => self.left_visual_start_row(),
             PaneFocus::Right => lines.len().saturating_sub(1),
         };
         let column = match pane {
@@ -1365,6 +1365,37 @@ impl TerminalUi {
         clamp_position(TextPosition { row, column }, lines)
     }
 
+    fn left_visual_start_row(&self) -> usize {
+        if self.control_selected == 0 {
+            return 0;
+        }
+
+        let selected_visible_position = self.control_selected.saturating_sub(1);
+        let mut row = 1;
+        for (visible_position, agent_index) in self.visible_agent_indices().iter().enumerate() {
+            if visible_position == selected_visible_position {
+                return row;
+            }
+
+            let agent = &self.agents[*agent_index];
+            row += 1;
+            if !agent.modified_files.is_empty() {
+                row += 1;
+            }
+            for linked_agents in [
+                &agent.conflicting_agents,
+                &agent.depends_on,
+                &agent.depended_on_by,
+            ] {
+                if !linked_agents.is_empty() {
+                    row += 1;
+                }
+            }
+        }
+
+        0
+    }
