+#[test]
+fn scripted_harness_visual_character_mode_anchors_on_expanded_left_agent_row() {
+    let mut harness = UiHarness::new(80, 24);
+
+    harness.handle_byte(b'j');
+    assert_eq!(
+        harness.ui().selected_agent().map(|id| id.as_str()),
+        Some("user-2")
+    );
+
+    harness.handle_byte(b'v');
+    harness.handle_byte(b'l');
+    harness.handle_byte(b'y');
+
+    let copied_frame = harness.render_frame();
+    assert!(copied_frame.starts_with("\u{1b}]52;c;PnQ=\u{7}\u{1b}[H"));
+    assert!(copied_frame.contains("copied 2 chars"));
+}
