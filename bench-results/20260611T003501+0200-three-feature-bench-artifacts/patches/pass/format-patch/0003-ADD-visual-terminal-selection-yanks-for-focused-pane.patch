+    fn handle_visual_key(&mut self, key: UiKey) -> Vec<UiAction> {
+        match key {
+            UiKey::Esc => self.visual_selection = None,
+            UiKey::Char('h') | UiKey::Left => self.move_visual_cursor(0, -1),
+            UiKey::Char('j') | UiKey::Down => self.move_visual_cursor(1, 0),
+            UiKey::Char('k') | UiKey::Up => self.move_visual_cursor(-1, 0),
+            UiKey::Char('l') | UiKey::Right => self.move_visual_cursor(0, 1),
+            UiKey::Char('v') => self.set_visual_kind(VisualSelectionKind::Character),
+            UiKey::Char('V') => self.set_visual_kind(VisualSelectionKind::Line),
+            _ => {}
+        }
+        Vec::new()
+    }
+
+    fn start_visual_selection(&mut self, right_content: &str, kind: VisualSelectionKind) {
+        let pane = self.selectable_focus();
+        let lines = self.selection_pane_lines(pane, right_content);
+        let bounds = self.visual_bounds_for_pane(pane, right_content);
+        let position = self.visual_start_position(pane, &lines, bounds);
+        self.mode = UiMode::Command;
+        self.pending = None;
+        self.visual_selection = Some(VisualSelection {
+            pane,
+            kind,
+            anchor: position,
+            cursor: position,
+            bounds,
+        });
+    }
+
+    fn selectable_focus(&self) -> PaneFocus {
+        if self.focus == PaneFocus::Left && !self.left_visible {
+            PaneFocus::Right
+        } else {
+            self.focus
+        }
+    }
+
+    fn visual_start_position(
+        &self,
+        pane: PaneFocus,
+        lines: &[String],
+        bounds: TextBounds,
+    ) -> TextPosition {
+        match pane {
+            PaneFocus::Left => TextPosition {
+                row: self
+                    .control_selected_text_row()
+                    .min(bounds.height.saturating_sub(1)),
+                column: 0,
+            },
+            PaneFocus::Right => {
+                let row = lines
+                    .len()
+                    .saturating_sub(1)
+                    .min(bounds.height.saturating_sub(1));
+                let column = lines
+                    .get(row)
+                    .map(|line| line.chars().count().saturating_sub(1))
+                    .unwrap_or(0)
+                    .min(bounds.width.saturating_sub(1));
+                TextPosition { row, column }
+            }
+        }
+    }
+
+    fn set_visual_kind(&mut self, kind: VisualSelectionKind) {
+        if let Some(selection) = &mut self.visual_selection {
+            selection.kind = kind;
+        }
+    }
+
+    fn move_visual_cursor(&mut self, row_delta: isize, column_delta: isize) {
+        let Some(selection) = &mut self.visual_selection else {
+            return;
+        };
+        selection.cursor.row =
+            offset_index(selection.cursor.row, row_delta, selection.bounds.height);
+        selection.cursor.column = offset_index(
+            selection.cursor.column,
+            column_delta,
+            selection.bounds.width,
+        );
+    }
+
+    fn visual_bounds_for_pane(&self, pane: PaneFocus, right_content: &str) -> TextBounds {
+        let body_height = self.height.saturating_sub(1);
+        let inner_height = usize::from(body_height.saturating_sub(2).max(1));
+        match pane {
+            PaneFocus::Left => {
+                let width = usize::from(self.layout().left_width.saturating_sub(2).max(1));
+                let height = self.left_pane_text_lines().len().max(1).min(inner_height);
+                TextBounds { width, height }
+            }
+            PaneFocus::Right => {
+                let (width, _) = self.right_inner_size();
+                let width = usize::from(width.max(1));
+                let height = self
+                    .selection_pane_lines(PaneFocus::Right, right_content)
+                    .len()
+                    .max(1)
+                    .min(inner_height);
+                TextBounds { width, height }
+            }
+        }
+    }
+
+    fn visual_cursor_position(&self, selection: &VisualSelection) -> (u16, u16) {
+        let row = 2_u16.saturating_add(selection.cursor.row.min(usize::from(u16::MAX)) as u16);
+        let column = match selection.pane {
+            PaneFocus::Left if self.left_visible => {
+                2_u16.saturating_add(selection.cursor.column.min(usize::from(u16::MAX)) as u16)
+            }
+            _ => self
+                .layout()
+                .left_width
+                .saturating_add(2)
+                .saturating_add(selection.cursor.column.min(usize::from(u16::MAX)) as u16),
+        };
+        (row, column)
+    }
+
+    fn visual_selection_overlay(
+        &self,
+        left_pane: Option<Rect>,
+        right_pane: Rect,
+    ) -> VisualSelectionOverlay {
+        let pane = self
+            .visual_selection
+            .as_ref()
+            .and_then(|selection| match selection.pane {
+                PaneFocus::Left => left_pane,
+                PaneFocus::Right => Some(right_pane),
+            });
+        VisualSelectionOverlay {
+            selection: self.visual_selection.clone(),
+            pane,
+        }
+    }
+
+    fn render_visual_selection(selection: &VisualSelection, pane: Rect, buffer: &mut Buffer) {
+        let inner = inner_rect(pane);
+        if inner.width == 0 || inner.height == 0 {
+            return;
+        }
+
+        let min_row = selection.anchor.row.min(selection.cursor.row);
+        let max_row = selection
+            .anchor
+            .row
+            .max(selection.cursor.row)
+            .min(usize::from(inner.height.saturating_sub(1)));
+        let min_column = selection.anchor.column.min(selection.cursor.column);
+        let max_column = selection
+            .anchor
+            .column
+            .max(selection.cursor.column)
+            .min(usize::from(inner.width.saturating_sub(1)));
+
