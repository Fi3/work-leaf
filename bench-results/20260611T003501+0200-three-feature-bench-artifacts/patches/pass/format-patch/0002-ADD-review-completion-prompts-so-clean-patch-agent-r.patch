+    ReopenAndSend,
+}
+
+const FEATURE_DONE_PROMPT: &str = "work-leaf: Is this feature done? yes/no";
+const FEATURE_CLOSED_MESSAGE: &str = "work-leaf: feature closed";
+const FEATURE_REOPENED_MESSAGE: &str = "work-leaf: feature reopened";
+
+fn feature_done_answer(message: &str) -> FeatureDoneAnswer {
+    match message.trim().to_ascii_lowercase().as_str() {
+        "yes" | "y" => FeatureDoneAnswer::Yes,
+        "no" | "n" => FeatureDoneAnswer::No,
+        _ => FeatureDoneAnswer::Other,
+    }
