+
+fn feature_done_prompt_line(review: &ReviewResult) -> String {
+    let short_hash = review.commit.hash.chars().take(12).collect::<String>();
+    if short_hash.is_empty() {
+        FEATURE_DONE_PROMPT.to_string()
+    } else {
+        format!("{FEATURE_DONE_PROMPT} ({short_hash})")
+    }
+}
+
+fn is_feature_done_prompt_line(line: &str) -> bool {
+    line.starts_with(FEATURE_DONE_PROMPT)
+}
+
+fn unique_session_line(existing_lines: &[String], line: &str) -> String {
+    let numbered_prefix = format!("{line} (");
+    let mut max_suffix = 0;
+    for existing in existing_lines {
+        if existing == line {
+            max_suffix = max_suffix.max(1);
+            continue;
+        }
+        let Some(suffix) = existing
+            .strip_prefix(&numbered_prefix)
+            .and_then(|suffix| suffix.strip_suffix(')'))
+            .and_then(|suffix| suffix.parse::<usize>().ok())
+        else {
+            continue;
+        };
+        max_suffix = max_suffix.max(suffix);
+    }
+
+    if max_suffix == 0 {
+        line.to_string()
+    } else {
+        format!("{line} ({})", max_suffix + 1)
+    }
+}
