+fn selected_agent_backend_command(message: &str) -> Option<&str> {
+    let trimmed = message.trim();
+    let command = trimmed.strip_prefix('/')?;
+    command
+        .chars()
+        .next()
+        .is_some_and(|ch| !ch.is_whitespace())
+        .then_some(trimmed)
+}
