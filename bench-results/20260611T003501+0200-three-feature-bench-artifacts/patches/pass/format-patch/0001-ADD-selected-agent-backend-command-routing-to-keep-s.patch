+#[test]
+fn controller_executes_selected_agent_slash_commands_through_backend_command_path() {
+    let backend = FakeBackend::new(["launch reply", "status output", "fork output"]);
+    let chat = CommandChat::new(PathBuf::from("/repo"), backend.clone());
+    let mut controller = WorkLeafController::new(chat);
+
+    let agent_id = controller.create_agent("inspect backend commands").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+
+    controller.send_message(&agent_id, "/status").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+    controller.send_message(&agent_id, "/fork").unwrap();
+    assert!(controller.wait_for_idle(Duration::from_secs(1)));
+
+    let snapshot = controller.snapshot();
+    let session = snapshot.session(&agent_id).expect("session exists");
+    assert!(session.lines.iter().any(|line| line == "user: /status"));
+    assert!(session.lines.iter().any(|line| line == "status output"));
+    assert!(session.lines.iter().any(|line| line == "user: /fork"));
+    assert!(session.lines.iter().any(|line| line == "fork output"));
+    assert_eq!(
+        backend.commands(),
+        vec![
+            (agent_id.clone(), "/status".to_string()),
+            (agent_id.clone(), "/fork".to_string()),
+        ]
+    );
+    assert!(
+        backend.sends().is_empty(),
+        "/status must not enter the ordinary prompt send path"
+    );
+}
