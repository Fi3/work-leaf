+    fn handle_visual_key(&mut self, key: UiKey, right_content: &str) -> Vec<UiAction> {
+        match key {
+            UiKey::Esc => {
+                self.clear_visual_selection();
+            }
+            UiKey::Char('v') => {
+                self.switch_visual_selection_mode(VisualSelectionMode::Character, right_content);
+            }
+            UiKey::Char('V') => {
+                self.switch_visual_selection_mode(VisualSelectionMode::Line, right_content);
+            }
+            UiKey::Char(VISUAL_BLOCK_CONTROL) => {
+                self.switch_visual_selection_mode(VisualSelectionMode::Block, right_content);
+            }
+            UiKey::Char('h') | UiKey::Left => {
+                self.move_visual_cursor(0, -1, right_content);
+            }
+            UiKey::Char('l') | UiKey::Right => {
+                self.move_visual_cursor(0, 1, right_content);
+            }
+            UiKey::Char('k') | UiKey::Up => {
+                self.move_visual_cursor(-1, 0, right_content);
+            }
+            UiKey::Char('j') | UiKey::Down => {
+                self.move_visual_cursor(1, 0, right_content);
+            }
+            UiKey::Char('y') => {
+                self.yank_visual_selection(right_content, false);
+            }
+            UiKey::Char('Y') => {
+                self.yank_visual_selection(right_content, true);
+            }
+            _ => {}
+        }
+        Vec::new()
+    }
+
+    fn begin_visual_selection(&mut self, mode: VisualSelectionMode, right_content: &str) {
+        let focus = self.focus;
+        let lines = self.selection_lines(focus, right_content);
+        let cursor = self.initial_visual_cursor(focus, &lines);
+        self.mode = UiMode::Command;
+        self.pending = None;
+        self.visual_selection = Some(VisualSelection {
+            focus,
+            mode,
+            anchor: cursor,
+            cursor,
+        });
+    }
+
+    fn switch_visual_selection_mode(&mut self, mode: VisualSelectionMode, right_content: &str) {
+        let Some(selection) = self.visual_selection.as_mut() else {
+            self.begin_visual_selection(mode, right_content);
+            return;
+        };
+        selection.mode = mode;
+        self.clamp_visual_selection(right_content);
+    }
+
+    fn move_visual_cursor(&mut self, line_delta: isize, column_delta: isize, right_content: &str) {
+        let Some(selection) = self.visual_selection.as_ref() else {
+            return;
+        };
+        let lines = self.selection_lines(selection.focus, right_content);
+        let max_line = lines.len().saturating_sub(1);
+
+        let Some(selection) = self.visual_selection.as_mut() else {
+            return;
+        };
+        selection.cursor.line = selection
+            .cursor
+            .line
+            .saturating_add_signed(line_delta)
+            .min(max_line);
+
+        let current_line_len = lines
+            .get(selection.cursor.line)
+            .map(|line| line.chars().count().saturating_sub(1))
+            .unwrap_or_default();
+        selection.cursor.column = selection
+            .cursor
+            .column
+            .saturating_add_signed(column_delta)
+            .min(current_line_len);
+    }
+
+    fn yank_visual_selection(&mut self, right_content: &str, force_line: bool) {
+        let Some(selection) = self.visual_selection.clone() else {
+            return;
+        };
+        let lines = self.selection_lines(selection.focus, right_content);
+        let text = selected_text(&lines, &selection, force_line);
+        let char_count = text.chars().count();
+        self.pending_yank = Some(text);
+        self.clear_visual_selection();
+        self.show_status_notice(
+            format!("work-leaf: copied {char_count} chars"),
+            Duration::from_secs(STATUS_NOTICE_SECONDS),
+        );
+    }
+
+    fn clear_visual_selection(&mut self) {
+        self.visual_selection = None;
+    }
+
+    fn clamp_visual_selection(&mut self, right_content: &str) {
+        let Some(selection) = self.visual_selection.as_ref() else {
+            return;
+        };
+        let lines = self.selection_lines(selection.focus, right_content);
+        let max_line = lines.len().saturating_sub(1);
+        let Some(selection) = self.visual_selection.as_mut() else {
+            return;
+        };
+        selection.anchor.line = selection.anchor.line.min(max_line);
+        selection.cursor.line = selection.cursor.line.min(max_line);
+        for cursor in [&mut selection.anchor, &mut selection.cursor] {
+            let max_column = lines
+                .get(cursor.line)
+                .map(|line| line.chars().count().saturating_sub(1))
+                .unwrap_or_default();
+            cursor.column = cursor.column.min(max_column);
+        }
+    }
+
+    fn selection_lines(&self, focus: PaneFocus, right_content: &str) -> Vec<String> {
+        match focus {
+            PaneFocus::Left => self
+                .left_widget_rows()
+                .into_iter()
+                .map(|row| row.text)
+                .collect(),
+            PaneFocus::Right => {
+                let visible_right_content = self.visible_right_content(right_content);
+                if visible_right_content.is_empty() {
+                    vec![String::new()]
+                } else {
+                    visible_right_content
+                        .lines()
+                        .map(ToString::to_string)
+                        .collect()
+                }
+            }
+        }
+    }
+
+    fn initial_visual_cursor(&self, focus: PaneFocus, lines: &[String]) -> TextCursor {
+        let max_line = lines.len().saturating_sub(1);
+        let line = match focus {
+            PaneFocus::Left => self.control_content_line().min(max_line),
+            PaneFocus::Right => 0,
+        };
+        TextCursor { line, column: 0 }
+    }
