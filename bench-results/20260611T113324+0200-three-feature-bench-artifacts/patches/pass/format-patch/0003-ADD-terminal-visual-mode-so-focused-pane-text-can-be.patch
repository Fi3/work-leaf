+fn left_agent_extra_row_count(agent: &AgentListEntry) -> usize {
+    usize::from(!agent.modified_files.is_empty())
+        + [
+            &agent.conflicting_agents,
+            &agent.depends_on,
+            &agent.depended_on_by,
+        ]
+        .into_iter()
+        .filter(|agents| !agents.is_empty())
+        .count()
+}
