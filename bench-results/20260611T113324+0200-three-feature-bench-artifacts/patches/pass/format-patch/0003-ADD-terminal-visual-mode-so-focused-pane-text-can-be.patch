 src/terminal_app.rs  |  34 ++-
 src/ui.rs            | 627 ++++++++++++++++++++++++++++++++++++++++++-
 src/ui_harness.rs    |  36 ++-
 tests/ui_harness.rs  |  44 +++
 5 files changed, 718 insertions(+), 27 deletions(-)

