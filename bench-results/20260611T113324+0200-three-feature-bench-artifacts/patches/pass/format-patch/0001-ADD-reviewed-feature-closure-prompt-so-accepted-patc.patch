+    fn close_feature_if_confirmed(&mut self, agent_id: &AgentId, message: &str) -> bool {
+        if !self.pending_feature_done_decisions.contains(agent_id)
+            || !is_feature_done_confirmation(message)
+        {
+            return false;
+        }
+
+        self.pending_feature_done_decisions.remove(agent_id);
+        self.closed_features.insert(agent_id.clone());
+        self.append_agent_line_allow_duplicate(agent_id, format!("user: {message}"));
+        self.append_agent_line_allow_duplicate(agent_id, FEATURE_CLOSED_NOTICE.to_string());
+        true
+    }
+
+    fn reopen_feature_if_needed(&mut self, agent_id: &AgentId) {
+        let had_pending_decision = self.pending_feature_done_decisions.remove(agent_id);
+        let was_closed = self.closed_features.remove(agent_id);
+        if had_pending_decision || was_closed {
+            self.append_agent_line_allow_duplicate(agent_id, FEATURE_REOPENED_NOTICE.to_string());
+        }
+    }
