+pub(crate) fn agent_backend_command(message: &str) -> Option<&str> {
+    let command = message.trim();
+    let after_slash = command.strip_prefix('/')?;
+    let first = after_slash.chars().next()?;
+    if first.is_whitespace() {
+        return None;
+    }
+    Some(command)
