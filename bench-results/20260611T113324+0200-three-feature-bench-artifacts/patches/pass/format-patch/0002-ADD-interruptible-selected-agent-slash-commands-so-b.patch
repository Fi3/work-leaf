+    fn run_command_streaming(
+        &mut self,
+        agent_id: &AgentId,
+        command: &str,
+        sink: &mut dyn FnMut(AgentStreamEvent),
+    ) -> Result<ChatMessage, AgentError> {
+        let invocation = self.build_command_invocation(agent_id, command)?;
+        let output = self.run_invocation_streaming(&invocation, Some(agent_id), sink)?;
+        let ParsedCodexOutput {
+            thread_id,
+            agent_reply,
+        } = parse_codex_output(&output);
+        let reply = agent_reply.unwrap_or(output);
+        let message = ChatMessage::new(MessageRole::Agent, reply);
+        let mut state = self
+            .state
+            .lock()
+            .expect("codex backend state mutex poisoned");
+        if let Some(thread_id) = thread_id {
+            state.thread_ids.insert(agent_id.clone(), thread_id);
+        }
+        if let Some(session) = state.sessions.get_mut(agent_id) {
+            session.push_message(MessageRole::User, command);
+        } else {
+            state.sessions.insert(
+                agent_id.clone(),
+                AgentSession::new(AgentLaunch::new(
+                    agent_id.clone(),
+                    AgentKind::Codex,
+                    "unknown",
+                    command,
+                )),
+            );
+        }
+        let session = state
+            .sessions
+            .get_mut(agent_id)
+            .ok_or_else(|| AgentError::UnknownSession(agent_id.clone()))?;
+        session.messages.push(message.clone());
+        Ok(message)
+    }
 }
 
