+        let (done_sender, done_receiver) = mpsc::channel();
+        let worker_agent_id = agent_id.clone();
+        let mut worker_backend = backend.clone();
+        thread::spawn(move || {
+            let mut started_sender = Some(started_sender);
+            let result =
+                worker_backend.run_command_streaming(&worker_agent_id, "/status", &mut |event| {
+                    if matches!(event, AgentStreamEvent::Status(_))
+                        && let Some(sender) = started_sender.take()
+                    {
+                        let _ = sender.send(());
+                    }
+                });
+            let _ = done_sender.send(result);
+        });
+
+        started_receiver
+            .recv_timeout(Duration::from_secs(1))
