      for (const mode of order) {
        if (mode !== 'All' && !counts[mode]) continue;
        const button = document.createElement('button');
        button.type = 'button';
        button.className = `mode-filter${activeMode === mode ? ' active' : ''}`;
        button.textContent = `${mode} (${counts[mode] || 0})`;
        button.addEventListener('click', () => {
          activeMode = mode;
          renderModeFilters();
          renderRows();
        });
        modeFilters.appendChild(button);
      }
    }

    function renderRows() {
      const query = filter.value.trim().toLowerCase();
      const counts = modeCounts();
      const visible = records.filter(record => {
        const modeMatches = activeMode === 'All' || record.kind === activeMode;
        return modeMatches && (!query || searchable(record).includes(query));
      });
      summary.textContent = `${visible.length} of ${records.length} reports; Work Leaf ${counts['Work Leaf'] || 0}, Sequential ${counts.Sequential || 0}, Worktree ${counts.Worktree || 0}`;
      if (visible.length === 0) {
        body.innerHTML = '<tr><td colspan="17">No bench reports match the filter.</td></tr>';
        return;
