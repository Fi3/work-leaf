class BenchDashboardHandler(BaseHTTPRequestHandler):
    results_dir: Path = DEFAULT_RESULTS_DIR

    def log_message(self, format_: str, *args: Any) -> None:
        sys.stderr.write("%s - - [%s] %s\n" % (self.address_string(), self.log_date_time_string(), format_ % args))

    def send_body(self, status: int, content_type: str, body: bytes) -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self) -> None:
        path = self.path.split("?", 1)[0]
        if path in ("/", "/index.html"):
            self.send_body(200, "text/html; charset=utf-8", render_index_html().encode("utf-8"))
            return
        if path == "/api/benches":
            records = collect_bench_records(self.results_dir)
            payload = {
                "results_dir": str(self.results_dir),
                "latest_reference": latest_reference(records),
                "records": records,
            }
            self.send_body(200, "application/json; charset=utf-8", json_bytes(payload))
            return
        if path.startswith("/api/report/"):
            report_name = path.removeprefix("/api/report/")
            try:
                body = read_report(self.results_dir, report_name).encode("utf-8")
            except FileNotFoundError:
                self.send_body(404, "text/plain; charset=utf-8", b"report not found\n")
                return
            self.send_body(200, "text/plain; charset=utf-8", body)
            return
        self.send_body(404, "text/plain; charset=utf-8", b"not found\n")


def serve(host: str, port: int, results_dir: Path) -> None:
    handler = type("ConfiguredBenchDashboardHandler", (BenchDashboardHandler,), {"results_dir": results_dir.resolve()})
    server = ThreadingHTTPServer((host, port), handler)
    bound_host, bound_port = server.server_address[:2]
    print(f"Serving Work Leaf bench dashboard at http://{bound_host}:{bound_port}", flush=True)
    print(f"Reading bench reports from {results_dir.resolve()}", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped bench dashboard.")
    finally:
        server.server_close()


def write(path: Path, text: str) -> None:
    path.write_text(text, encoding="utf-8")


