ROOT = Path(__file__).resolve().parent
DEFAULT_RESULTS_DIR = ROOT / "bench-results"
TOKEN_RE = re.compile(r"(cached_input|reasoning_output|input|output)=(\d+)")
META_RE = re.compile(r"^- ([A-Za-z0-9_]+):\s*(.*)$")


def parse_json_stream(text: str) -> list[dict[str, Any]]:
    decoder = json.JSONDecoder()
    records: list[dict[str, Any]] = []
    index = 0
    while index < len(text):
        while index < len(text) and text[index].isspace():
            index += 1
        if index >= len(text):
            break
        try:
            value, end = decoder.raw_decode(text, index)
        except json.JSONDecodeError:
            next_start = text.find("{", index + 1)
            if next_start == -1:
                break
            index = next_start
            continue
        if isinstance(value, dict):
            records.append(value)
        index = end
    return records


def parse_markdown_metadata(text: str) -> dict[str, str]:
    fields: dict[str, str] = {}
    for line in text.splitlines():
        match = META_RE.match(line)
        if match:
            fields[match.group(1)] = match.group(2).strip()
    return fields


def parse_token_totals(token_usage: str | None) -> dict[str, int]:
    totals = {
        "input": 0,
        "cached_input": 0,
        "uncached_input": 0,
        "output": 0,
        "reasoning_output": 0,
    }
    if not token_usage:
        return totals
    for key, value in TOKEN_RE.findall(token_usage):
        totals[key] += int(value)
    totals["uncached_input"] = max(0, totals["input"] - totals["cached_input"])
    return totals


def int_or_none(value: Any) -> int | None:
    if value is None:
        return None
    if isinstance(value, int):
        return value
    text = str(value).strip()
    if not text or text.lower() == "null":
        return None
    try:
        return int(text)
    except ValueError:
        return None


def value(fields: dict[str, Any], *keys: str) -> Any:
    for key in keys:
        if fields.get(key) not in (None, ""):
            return fields[key]
    return None


def classify_bench(report_name: str, fields: dict[str, Any]) -> str:
    hints = " ".join(
        str(part)
        for part in (
            report_name,
            value(fields, "bench_mode"),
            value(fields, "bench_kind"),
            value(fields, "report"),
            value(fields, "patch_artifacts"),
        )
        if part
    ).lower()
    if "sequential" in hints:
        return "Sequential"
    if "worktree" in hints:
        return "Worktree"
    return "Work Leaf"


def infer_report_name(run_id: str, fields: dict[str, Any], index_name: str) -> str | None:
    report = value(fields, "report")
    if report:
        return Path(str(report)).name
    if not run_id:
        return None
    mode = str(value(fields, "bench_mode") or "").lower()
    if mode == "sequential" or "sequential" in index_name:
        return f"{run_id}-three-feature-sequential-bench.md"
    if mode == "worktree" or "worktree" in index_name:
        return f"{run_id}-three-feature-worktree-bench.md"
    return f"{run_id}-three-feature-bench.md"


def report_files(results_dir: Path) -> list[Path]:
    if not results_dir.exists():
        return []
    return sorted(
        path
        for path in results_dir.glob("*.md")
        if is_bench_report_name(path.name)
    )


def is_bench_report_name(name: str) -> bool:
    lowered = name.lower()
    if "direct-comparison" in lowered or "interim-baseline" in lowered:
        return False
    return "three-feature" in lowered and (
        "bench" in lowered or "sequential" in lowered or "worktree" in lowered
    )


def normalize_record(
    fields: dict[str, Any],
    report_name: str,
    markdown_text: str | None = None,
) -> dict[str, Any]:
    run_id = str(value(fields, "run_id") or report_name.split("-three-feature", 1)[0])
    tokens = parse_token_totals(str(value(fields, "token_usage") or ""))
    changed_added = int_or_none(value(fields, "changed_lines_added", "added_lines"))
    changed_deleted = int_or_none(value(fields, "changed_lines_deleted", "deleted_lines"))
    changed_total = int_or_none(value(fields, "changed_lines_total", "total_line_delta"))
    if changed_total is None and changed_added is not None and changed_deleted is not None:
        changed_total = changed_added + changed_deleted
    result = str(value(fields, "result") or "unknown")
    code_quality = str(value(fields, "code_quality") or "")
    final_checks = "pass" if code_quality.startswith("passed ") else ("not run" if code_quality == "not run" else code_quality or "unknown")
    kind = classify_bench(report_name, fields)

    return {
        "id": report_name,
        "report_file": report_name,
        "kind": kind,
        "run_id": run_id,
        "result": result,
        "duration_seconds": int_or_none(value(fields, "duration_seconds")),
        "input_tokens": tokens["input"],
        "cached_input_tokens": tokens["cached_input"],
        "uncached_input_tokens": tokens["uncached_input"],
        "output_tokens": tokens["output"],
        "reasoning_output_tokens": tokens["reasoning_output"],
        "review_completed": str(value(fields, "review_completed") or "unknown"),
        "linearize_completed": str(value(fields, "linearize_completed") or "unknown"),
        "commits_after_base": int_or_none(value(fields, "commits_after_base")),
        "changed_files": int_or_none(value(fields, "changed_files")),
        "changed_lines_added": changed_added,
        "changed_lines_deleted": changed_deleted,
        "changed_lines_total": changed_total,
        "final_checks": final_checks,
        "agent_model": str(value(fields, "agent_model") or "unknown"),
        "agent_transport": str(value(fields, "agent_transport") or "unknown"),
        "no_read_permission": str(value(fields, "no_read_permission") or "unknown"),
        "benched_binary_commit": str(value(fields, "benched_binary_commit", "bench_driver_commit") or "unknown"),
        "benched_binary_dirty": str(value(fields, "benched_binary_dirty", "bench_driver_dirty") or "unknown"),
        "operator_notes": str(value(fields, "operator_notes", "human_operator_note") or ""),
        "markdown_preview": markdown_text.splitlines()[0] if markdown_text else "",
    }


def collect_bench_records(results_dir: Path) -> list[dict[str, Any]]:
    results_dir = results_dir.resolve()
    merged: dict[str, dict[str, Any]] = {}

    if results_dir.exists():
        for index_path in sorted(results_dir.glob("*.jsonl")):
            for fields in parse_json_stream(index_path.read_text(encoding="utf-8", errors="replace")):
                run_id = str(value(fields, "run_id") or "")
                report_name = infer_report_name(run_id, fields, index_path.name)
                if not report_name or not is_bench_report_name(report_name):
                    continue
                md_path = results_dir / report_name
                md_text = md_path.read_text(encoding="utf-8", errors="replace") if md_path.exists() else None
                md_fields = parse_markdown_metadata(md_text) if md_text else {}
                combined = {**md_fields, **fields}
                merged[report_name] = normalize_record(combined, report_name, md_text)

    for md_path in report_files(results_dir):
        if md_path.name in merged:
            continue
        md_text = md_path.read_text(encoding="utf-8", errors="replace")
        fields = parse_markdown_metadata(md_text)
        merged[md_path.name] = normalize_record(fields, md_path.name, md_text)

    return sorted(
        merged.values(),
        key=lambda record: str(record.get("run_id") or record.get("report_file") or ""),
        reverse=True,
    )


def latest_reference(records: list[dict[str, Any]]) -> str:
    if not records:
        return "no benchmark report found"
    latest = records[0]
    return (
        f"{latest['run_id']} ({latest['kind']}, {latest['result']}, "
        f"model {latest['agent_model']})"
    )


def read_report(results_dir: Path, report_name: str) -> str:
    decoded = unquote(report_name)
    if decoded != Path(decoded).name or "/" in decoded or "\\" in decoded:
        raise FileNotFoundError(decoded)
    if not is_bench_report_name(decoded):
        raise FileNotFoundError(decoded)
    report_path = results_dir.resolve() / decoded
    if not report_path.exists() or not report_path.is_file():
        raise FileNotFoundError(decoded)
    return report_path.read_text(encoding="utf-8", errors="replace")


def json_bytes(value_: Any) -> bytes:
    return json.dumps(value_, indent=2, sort_keys=True).encode("utf-8")


