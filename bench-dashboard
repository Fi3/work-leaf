def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Serve Work Leaf bench-results as a local HTML dashboard.")
    parser.add_argument("--host", default=os.environ.get("WORK_LEAF_BENCH_DASHBOARD_HOST", "127.0.0.1"))
    parser.add_argument("--port", type=int, default=int(os.environ.get("WORK_LEAF_BENCH_DASHBOARD_PORT", "8765")))
    parser.add_argument(
        "--results-dir",
        type=Path,
        default=Path(os.environ.get("WORK_LEAF_BENCH_RESULTS_DIR", DEFAULT_RESULTS_DIR)),
        help="benchmark results directory, default bench-results",
    )
    parser.add_argument("--self-test", action="store_true", help="run parser and HTML contract tests")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    if args.self_test:
        run_self_test()
        return 0
    serve(args.host, args.port, args.results_dir)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
