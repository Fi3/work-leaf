      body.innerHTML = '';
      for (const record of visible) {
        const tr = document.createElement('tr');
        tr.title = 'Open saved benchmark report';
        tr.innerHTML = `
          <td><span class="badge">${escapeHtml(record.kind)}</span></td>
          <td><code>${escapeHtml(record.run_id)}</code></td>
          <td><span class="${statusClass(record.result)}">${record.result}</span></td>
