          <td class="num">${number(record.input_tokens)}</td>
          <td class="num">${number(record.uncached_input_tokens)}</td>
          <td class="num">${number(record.output_tokens)}</td>
          <td class="num">${number(record.reasoning_output_tokens)}</td>
          <td><span class="${statusClass(record.review_completed)}">${record.review_completed}</span></td>
          <td><span class="${statusClass(record.linearize_completed)}">${record.linearize_completed}</span></td>
          <td class="num">${number(record.commits_after_base)}</td>
          <td class="num">${number(record.changed_files)}</td>
          <td class="num">${lineDelta(record)}</td>
          <td>${escapeHtml(record.final_checks)}</td>
          <td>${escapeHtml(record.agent_model)}</td>
          <td>${escapeHtml(record.agent_transport)}</td>
          <td>${escapeHtml(record.benched_binary_dirty)}</td>
        `;
        tr.addEventListener('click', () => openReport(record.report_file));
        body.appendChild(tr);
      }
    }

    async function openReport(reportFile) {
      history.pushState({ reportFile }, '', `#report=${encodeURIComponent(reportFile)}`);
      await showReport(reportFile);
    }

    async function showReport(reportFile) {
      home.classList.add('hidden');
      report.style.display = 'block';
      reportTitle.textContent = reportFile;
      reportContent.textContent = 'Loading report...';
      const response = await fetch(`/api/report/${encodeURIComponent(reportFile)}`);
      if (!response.ok) {
        reportContent.textContent = `Failed to load ${reportFile}: HTTP ${response.status}`;
        return;
      }
      reportContent.textContent = await response.text();
    }

    function showHome() {
      history.pushState({}, '', location.pathname);
      report.style.display = 'none';
      home.classList.remove('hidden');
    }

    back.addEventListener('click', showHome);
    filter.addEventListener('input', renderRows);
    window.addEventListener('popstate', () => route());

    function route() {
      const match = location.hash.match(/^#report=(.+)$/);
      if (match) {
        showReport(decodeURIComponent(match[1]));
      } else {
        report.style.display = 'none';
        home.classList.remove('hidden');
      }
    }

    async function load() {
      const response = await fetch('/api/benches');
      const payload = await response.json();
      records = payload.records || [];
      latestReference.textContent = payload.latest_reference || 'no benchmark report found';
      renderModeFilters();
      renderRows();
      route();
    }

    load().catch(error => {
      body.innerHTML = `<tr><td colspan="17">Failed to load bench reports: ${error}</td></tr>`;
      latestReference.textContent = 'bench reports failed to load';
    });
  </script>
